# Variables de entorno para VectoAgent
# Copia este archivo como .env y completa los valores

# Google AI Studio — https://aistudio.google.com (gratis)
GOOGLE_API_KEY=tu_google_api_key

# Google OAuth (Calendar)
# Crea credenciales OAuth en Google Cloud Console.
# El redirect local se gestiona por el flujo installed app.
GOOGLE_OAUTH_CLIENT_ID=tu_client_id
GOOGLE_OAUTH_CLIENT_SECRET=tu_client_secret

# Donde persistir el token OAuth del usuario (NO commitear)
GOOGLE_OAUTH_TOKEN_PATH=./.secrets/google_token.json

# LangSmith — https://smith.langchain.com (gratis)
LANGCHAIN_API_KEY=tu_langchain_api_key
LANGCHAIN_PROJECT=VectoAgent
LANGCHAIN_TRACING_V2=true

# Base de conocimiento (Markdown)
KNOWLEDGE_BASE_DIR=data/markdown
KNOWLEDGE_BASE_GLOB=**/*.md

# Chunking
CHUNK_SIZE=700
CHUNK_OVERLAP=120

# Recuperacion
RETRIEVER_K=3

# Persistencia Chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=vectoagent_docs
CHROMA_RESET_ON_START=false

# MCP Google Calendar (opcional)
# Habilitar conexion a MCP server de Google Calendar
MCP_GCAL_ENABLED=false
# Comando para ejecutar el server (ej: python)
MCP_GCAL_COMMAND=python
# Argumentos adicionales (separados por comas)
MCP_GCAL_ARGS=
# Script del server MCP
MCP_GCAL_SCRIPT=mcp_google_calendar_server.py
